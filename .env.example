# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost/citation_analysis
# For local development with SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./citation_analysis.db

# Semantic Scholar
SEMANTIC_SCHOLAR_API_KEY=your_key_here
S2_RATE_LIMIT=5

# OpenReview (optional)
OPENREVIEW_USER=your_email
OPENREVIEW_PASSWORD=your_password

# App
DEBUG=true
SECRET_KEY=change_me_in_production

# Pipeline
PIPELINE_NIGHTLY_HOUR=2
VENUES_TO_TRACK=NeurIPS,ICML,ICLR,CVPR,ICCV,ECCV,ACL,EMNLP,NAACL,AAAI,IJCAI,RSS,CoRL,INTERSPEECH
YEAR_RANGE_START=2015
